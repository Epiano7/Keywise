<Window x:Class="DesktopUsageAnalytics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Desktop Usage Analytics" Height="680" Width="1040" MinHeight="620" MinWidth="920"
        Background="#F5F7FA" Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Border" x:Key="MetricCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E0EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricLabel">
            <Setter Property="Foreground" Value="#526070"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricValue">
            <Setter Property="Foreground" Value="#142033"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#142033" Padding="20,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Desktop Usage Analytics" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Local aggregate input counters. No text, sequences, windows, clipboard, coordinates, or network telemetry."
                               Foreground="#C9D4E2" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="TrackingToggleButton" Click="TrackingToggleButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Margin="20">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,18,0,0">
                        <UniformGrid Columns="4">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Active tracking time"/>
                                    <TextBlock x:Name="ActiveTimeText" Style="{StaticResource MetricValue}" Text="0m"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Current session"/>
                                    <TextBlock x:Name="SessionText" Style="{StaticResource MetricValue}" Text="0m"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Total key presses"/>
                                    <TextBlock x:Name="KeyTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Total mouse clicks"/>
                                    <TextBlock x:Name="MouseTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Columns="3">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Left clicks"/>
                                    <TextBlock x:Name="LeftClickText" Style="{StaticResource MetricValue}" Text="0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Right clicks"/>
                                    <TextBlock x:Name="RightClickText" Style="{StaticResource MetricValue}" Text="0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MetricLabel}" Text="Keys per active hour"/>
                                    <TextBlock x:Name="KeysPerHourText" Style="{StaticResource MetricValue}" Text="0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Background="White" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,8,0,12">
                            <StackPanel>
                                <TextBlock Text="Most used keys" FontSize="17" FontWeight="SemiBold" Foreground="#142033"/>
                                <ItemsControl x:Name="TopKeysList" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Prototype input simulator" FontSize="17" FontWeight="SemiBold" Foreground="#142033"/>
                                <TextBlock Text="This test area exercises the aggregate counter model without installing a global Windows input hook yet."
                                           Foreground="#526070" Margin="0,4,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Add A key" Click="SimulateA_Click"/>
                                    <Button Content="Add Enter key" Click="SimulateEnter_Click"/>
                                    <Button Content="Add left click" Click="SimulateLeft_Click"/>
                                    <Button Content="Add right click" Click="SimulateRight_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Privacy">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,18,0,0">
                        <Border Background="#FFF8E5" BorderBrush="#D8B84F" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                            <TextBlock TextWrapping="Wrap" Foreground="#4A3B00">
                                <Run FontWeight="SemiBold" Text="Disclaimer: "/>
                                <Run Text="This prototype is AI-generated and has not yet completed a formal penetration test. Do not describe it as thoroughly pentested until that review is finished and documented."/>
                            </TextBlock>
                        </Border>

                        <UniformGrid Columns="2">
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="Collected" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Total count per key" Margin="0,12,0,0"/>
                                    <TextBlock Text="Left, right, and middle mouse click totals"/>
                                    <TextBlock Text="Total active tracking time"/>
                                    <TextBlock Text="Coarse daily aggregate totals"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricCard}">
                                <StackPanel>
                                    <TextBlock Text="Never collected" FontSize="17" FontWeight="SemiBold"/>
                                    <TextBlock Text="Typed text or key sequences" Margin="0,12,0,0"/>
                                    <TextBlock Text="Per-key timestamps"/>
                                    <TextBlock Text="Window titles, app names, URLs, or clipboard data"/>
                                    <TextBlock Text="Screenshots, screen contents, or mouse coordinates"/>
                                    <TextBlock Text="Network telemetry"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Background="White" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Local data path" FontSize="17" FontWeight="SemiBold" Foreground="#142033"/>
                                <TextBox x:Name="DataPathText" IsReadOnly="True" Margin="0,12,0,12"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save now" Click="SaveNow_Click"/>
                                    <Button Content="Reset counts" Click="ResetCounts_Click"/>
                                    <Button Content="Delete local data" Click="DeleteLocalData_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Settings">
                <StackPanel Margin="0,18,0,0">
                    <Border Background="White" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Startup" FontSize="17" FontWeight="SemiBold"/>
                            <CheckBox x:Name="StartAtLoginCheckBox" Content="Start app when I sign in" Margin="0,12,0,6"
                                      Checked="StartAtLoginCheckBox_Changed" Unchecked="StartAtLoginCheckBox_Changed"/>
                            <TextBlock Text="The prototype does not silently create startup entries. Installer support will add explicit opt-in shortcut creation."
                                       Foreground="#526070" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" BorderBrush="#D9E0EA" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Install layout plan" FontSize="17" FontWeight="SemiBold"/>
                            <TextBlock Text="App: %LOCALAPPDATA%\Programs\DesktopUsageAnalytics\" Margin="0,12,0,0"/>
                            <TextBlock Text="Data: %LOCALAPPDATA%\DesktopUsageAnalytics\"/>
                            <TextBlock Text="Startup opt-in: Startup folder shortcut"/>
                            <TextBlock Text="Uninstall: remove app files, shortcuts, startup entry, and optionally local data"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
