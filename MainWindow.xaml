<Window x:Class="DesktopUsageAnalytics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Keywise" Height="720" Width="1100" MinHeight="660" MinWidth="940"
        Background="#EEF2F6" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#132033"/>
        <SolidColorBrush x:Key="Muted" Color="#627084"/>
        <SolidColorBrush x:Key="Line" Color="#D8E0EA"/>
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Accent" Color="#167A7F"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#E3F4F2"/>
        <SolidColorBrush x:Key="Caution" Color="#F7C948"/>

        <Style TargetType="Border" x:Key="MetricCard">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="MinHeight" Value="116"/>
        </Style>
        <Style TargetType="Border" x:Key="PanelCard">
            <Setter Property="Background" Value="{StaticResource Panel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricLabel">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricValue">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderBrush" Value="#C7D1DD"/>
            <Setter Property="Background" Value="#FAFBFC"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#142033" Padding="26,22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource Accent}" Width="42" Height="42" CornerRadius="8" Margin="0,0,14,0">
                            <TextBlock Text="K" Foreground="White" FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Keywise" Foreground="White" FontSize="29" FontWeight="SemiBold"/>
                            <TextBlock Text="Private keyboard and mouse usage totals for your own PC"
                                       Foreground="#C9D4E2" FontSize="13" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#203149" BorderBrush="#37506E" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                        <TextBlock x:Name="StatusText" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                    <Button x:Name="TrackingToggleButton" Click="TrackingToggleButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource AccentSoft}" BorderBrush="#B6DEDA" BorderThickness="1"
                    CornerRadius="8" Padding="14,11" Margin="0,0,0,16">
                <TextBlock Foreground="#245052" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Local-only by design. "/>
                    <Run Text="Keywise stores aggregate counts and active time, not typed text, key sequences, windows, clipboard data, screen contents, or mouse coordinates."/>
                </TextBlock>
            </Border>

            <TabControl Grid.Row="1">
                <TabItem Header="Dashboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Today and lifetime totals" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Ink}" Margin="0,0,0,14"/>

                            <UniformGrid Columns="4">
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Active tracking time"/>
                                        <TextBlock x:Name="ActiveTimeText" Style="{StaticResource MetricValue}" Text="0m"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Current session"/>
                                        <TextBlock x:Name="SessionText" Style="{StaticResource MetricValue}" Text="0m"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Total key presses"/>
                                        <TextBlock x:Name="KeyTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Total mouse clicks"/>
                                        <TextBlock x:Name="MouseTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <UniformGrid Columns="3">
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Left clicks"/>
                                        <TextBlock x:Name="LeftClickText" Style="{StaticResource MetricValue}" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Right clicks"/>
                                        <TextBlock x:Name="RightClickText" Style="{StaticResource MetricValue}" Text="0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Keys per active hour"/>
                                        <TextBlock x:Name="KeysPerHourText" Style="{StaticResource MetricValue}" Text="0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0,8,14,14">
                                    <StackPanel>
                                        <TextBlock Text="Most used keys" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Aggregated totals only" Foreground="{StaticResource Muted}" Margin="0,3,0,12"/>
                                        <ItemsControl x:Name="TopKeysList"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource PanelCard}" Margin="0,8,0,14">
                                    <StackPanel>
                                        <TextBlock Text="Test inputs" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Useful while shaping the model." Foreground="{StaticResource Muted}" Margin="0,3,0,14"/>
                                        <WrapPanel>
                                            <Button Content="A key" Click="SimulateA_Click"/>
                                            <Button Content="Enter" Click="SimulateEnter_Click"/>
                                            <Button Content="Left click" Click="SimulateLeft_Click"/>
                                            <Button Content="Right click" Click="SimulateRight_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Privacy">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,18,0,0">
                            <Border Background="#FFF8E5" BorderBrush="{StaticResource Caution}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,14">
                                <TextBlock TextWrapping="Wrap" Foreground="#4A3B00">
                                    <Run FontWeight="SemiBold" Text="Security status: "/>
                                    <Run Text="This prototype is AI-generated and has not yet completed a formal penetration test. Do not describe it as thoroughly pentested until that review is finished and documented."/>
                                </TextBlock>
                            </Border>

                            <UniformGrid Columns="2">
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Text="Collected" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Total count per key" Margin="0,12,0,0"/>
                                        <TextBlock Text="Left, right, and middle mouse click totals"/>
                                        <TextBlock Text="Total active tracking time"/>
                                        <TextBlock Text="Coarse daily aggregate totals"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Text="Never collected" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                        <TextBlock Text="Typed text or key sequences" Margin="0,12,0,0"/>
                                        <TextBlock Text="Per-key timestamps"/>
                                        <TextBlock Text="Window titles, app names, URLs, or clipboard data"/>
                                        <TextBlock Text="Screenshots, screen contents, or mouse coordinates"/>
                                        <TextBlock Text="Network telemetry"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="Local data path" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                    <TextBox x:Name="DataPathText" IsReadOnly="True" Margin="0,12,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Save now" Click="SaveNow_Click"/>
                                        <Button Content="Reset counts" Click="ResetCounts_Click"/>
                                        <Button Content="Delete local data" Click="DeleteLocalData_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Settings">
                    <StackPanel Margin="0,18,0,0">
                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Startup" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                <CheckBox x:Name="StartAtLoginCheckBox" Content="Start Keywise when I sign in" Margin="0,12,0,6"
                                          Checked="StartAtLoginCheckBox_Changed" Unchecked="StartAtLoginCheckBox_Changed"/>
                                <TextBlock Text="The prototype does not silently create startup entries. Installer support will add explicit opt-in shortcut creation."
                                           Foreground="{StaticResource Muted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Install layout plan" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                                <TextBlock Text="App: %LOCALAPPDATA%\Programs\Keywise\" Margin="0,12,0,0"/>
                                <TextBlock Text="Data: %LOCALAPPDATA%\Keywise\"/>
                                <TextBlock Text="Startup opt-in: Startup folder shortcut"/>
                                <TextBlock Text="Uninstall: remove app files, shortcuts, startup entry, and optionally local data"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
