<Window x:Class="DesktopUsageAnalytics.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Keywise" Height="740" Width="1140" MinHeight="680" MinWidth="980"
        Icon="Assets/keywise.ico"
        ShowInTaskbar="True"
        FontFamily="Segoe UI"
        Background="{DynamicResource AppBackground}" Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#EEF3F7"/>
        <SolidColorBrush x:Key="HeaderBackground" Color="#111827"/>
        <SolidColorBrush x:Key="HeaderBorder" Color="#253247"/>
        <SolidColorBrush x:Key="Panel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelAlt" Color="#F7FAFC"/>
        <SolidColorBrush x:Key="Line" Color="#D6E0EA"/>
        <SolidColorBrush x:Key="Ink" Color="#111827"/>
        <SolidColorBrush x:Key="Muted" Color="#607084"/>
        <SolidColorBrush x:Key="Accent" Color="#0F8B8D"/>
        <SolidColorBrush x:Key="AccentStrong" Color="#0B6F73"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#E1F4F2"/>
        <SolidColorBrush x:Key="AccentInk" Color="#12494B"/>
        <SolidColorBrush x:Key="ButtonBg" Color="#FAFCFE"/>
        <SolidColorBrush x:Key="ButtonFg" Color="#172033"/>
        <SolidColorBrush x:Key="ButtonBorder" Color="#C7D2DE"/>
        <SolidColorBrush x:Key="DangerSoft" Color="#FFF1F2"/>
        <SolidColorBrush x:Key="WarningSoft" Color="#FFF8E1"/>
        <SolidColorBrush x:Key="WarningBorder" Color="#E8BE3E"/>
        <SolidColorBrush x:Key="WarningInk" Color="#4E3A00"/>
        <SolidColorBrush x:Key="StatusBg" Color="#203149"/>
        <SolidColorBrush x:Key="StatusBorder" Color="#3A516F"/>
        <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

        <Style TargetType="Border" x:Key="MetricCard">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,14,14"/>
            <Setter Property="MinHeight" Value="118"/>
        </Style>
        <Style TargetType="Border" x:Key="PanelCard">
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricLabel">
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="MetricValue">
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="148"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonFg}"/>
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AccentSoft}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="NavButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="134"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="Background" Value="{DynamicResource PanelAlt}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Height="{TemplateBinding Height}" MinWidth="{TemplateBinding MinWidth}"
                                Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentInk}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="{DynamicResource Line}"/>
            <Setter Property="Background" Value="{DynamicResource PanelAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Ink}"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
        <DataTemplate x:Key="TopKeyTemplate">
            <Border Background="{DynamicResource PanelAlt}" BorderBrush="{DynamicResource Line}" BorderThickness="1"
                    CornerRadius="8" Padding="12,9" Margin="0,0,8,8">
                <TextBlock Text="{Binding}" FontSize="14" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBackground}" BorderBrush="{DynamicResource HeaderBorder}"
                BorderThickness="0,0,0,1" Padding="28,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="64" Height="64" CornerRadius="8" Margin="0,0,16,0" Background="{DynamicResource Panel}" ClipToBounds="True">
                        <Image Source="pack://application:,,,/Assets/keywise-logo-source.png" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Keywise" Foreground="White" FontSize="30" FontWeight="SemiBold"/>
                        <TextBlock Text="Private usage totals for your keyboard and mouse"
                                   Foreground="#B8C5D6" FontSize="13" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource StatusBg}" BorderBrush="{DynamicResource StatusBorder}" BorderThickness="1"
                            CornerRadius="4" Height="44" MinWidth="150" Padding="18,0" Margin="0,0,10,8">
                        <TextBlock x:Name="StatusText" Foreground="White" FontWeight="SemiBold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                    </Border>
                    <Button x:Name="TrackingToggleButton" Click="TrackingToggleButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource AccentSoft}" BorderBrush="{DynamicResource Accent}" BorderThickness="1"
                    CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                <TextBlock Foreground="{DynamicResource AccentInk}" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Text="Local-only by design. "/>
                    <Run Text="Keywise stores aggregate counts and active time, not typed text, key sequences, windows, clipboard data, screen contents, or mouse coordinates."/>
                </TextBlock>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,16" HorizontalAlignment="Left">
                <Button x:Name="DashboardNavButton" Style="{StaticResource NavButton}" Content="Dashboard" Click="DashboardNavButton_Click"/>
                <Button x:Name="InputsNavButton" Style="{StaticResource NavButton}" Content="Inputs" Click="InputsNavButton_Click"/>
                <Button x:Name="PrivacyNavButton" Style="{StaticResource NavButton}" Content="Privacy" Click="PrivacyNavButton_Click"/>
                <Button x:Name="SettingsNavButton" Style="{StaticResource NavButton}" Content="Settings" Click="SettingsNavButton_Click"/>
            </StackPanel>

            <TabControl x:Name="MainTabs" Grid.Row="2" SelectionChanged="MainTabs_SelectionChanged">
                <TabItem Header="Dashboard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Stats" FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Your high-level Keywise totals" Foreground="{DynamicResource Muted}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <UniformGrid Columns="5">
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Total time"/>
                                        <TextBlock x:Name="ActiveTimeText" Style="{StaticResource MetricValue}" Text="0m" FontSize="29"/>
                                        <TextBlock Text="Total enabled time" Foreground="{DynamicResource Muted}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Session"/>
                                        <TextBlock x:Name="SessionText" Style="{StaticResource MetricValue}" Text="0m" FontSize="29"/>
                                        <TextBlock Text="Current run" Foreground="{DynamicResource Muted}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Sessions"/>
                                        <TextBlock x:Name="SessionCountText" Style="{StaticResource MetricValue}" Text="0"/>
                                        <TextBlock Text="App launches" Foreground="{DynamicResource Muted}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Keys"/>
                                        <TextBlock x:Name="KeyTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                        <TextBlock Text="Total presses" Foreground="{DynamicResource Muted}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabel}" Text="Clicks"/>
                                        <TextBlock x:Name="MouseTotalText" Style="{StaticResource MetricValue}" Text="0"/>
                                        <TextBlock Text="Mouse buttons" Foreground="{DynamicResource Muted}" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Inputs">
                    <DockPanel Margin="0,0,10,20">
                            <Border DockPanel.Dock="Top" Style="{StaticResource PanelCard}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="All Inputs" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock Text="Keyboard keys and mouse buttons, shown as aggregate totals only." Foreground="{DynamicResource Muted}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="InputSortComboBox" Grid.Column="1" Width="190" VerticalAlignment="Center" SelectionChanged="InputSortComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Most used first" Tag="desc"/>
                                        <ComboBoxItem Content="Least used first" Tag="asc"/>
                                        <ComboBoxItem Content="Name A-Z" Tag="name"/>
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <ListView x:Name="AllInputsList"
                                      Background="{DynamicResource Panel}"
                                      BorderBrush="{DynamicResource Line}"
                                      Foreground="{DynamicResource Ink}"
                                      ScrollViewer.CanContentScroll="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Input" DisplayMemberBinding="{Binding Name}" Width="260"/>
                                        <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Kind}" Width="140"/>
                                        <GridViewColumn Header="Count" DisplayMemberBinding="{Binding Count}" Width="160"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                    </DockPanel>
                </TabItem>

                <TabItem Header="Privacy">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                        <StackPanel Margin="0,0,0,20">
                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="Privacy Notice" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="23" Margin="0,12,0,0">
                                        Keywise is built to count your own computer usage without recording what you type or what you do on screen. When tracking is enabled, it saves local totals such as how many times each key or mouse button was pressed and how long tracking was active. It does not save typed words, key sequences, per-key timestamps, app names, window titles, websites, clipboard data, screenshots, mouse position, or screen contents. Your data stays on this computer unless you choose to export or share it. Keywise only contacts GitHub when you click the update button. This build was AI-assisted and has not yet completed a formal penetration test.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelCard}">
                                <StackPanel>
                                    <TextBlock Text="Local Data" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBox x:Name="DataPathText" IsReadOnly="True" Margin="0,12,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Save now" Click="SaveNow_Click"/>
                                        <Button Content="Reset counts" Click="ResetCounts_Click"/>
                                        <Button Content="Delete local data" Click="DeleteLocalData_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                    <StackPanel Margin="0,0,0,20">
                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Startup" FontSize="18" FontWeight="SemiBold"/>
                                <CheckBox x:Name="StartAtLoginCheckBox" Content="Start Keywise when I sign in" Margin="0,12,0,6"
                                          Foreground="{DynamicResource Ink}" Checked="StartAtLoginCheckBox_Changed" Unchecked="StartAtLoginCheckBox_Changed"/>
                                <TextBlock Text="Disabled by default. When enabled, Keywise creates a visible Startup folder shortcut that you can remove at any time."
                                           Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Window Behavior" FontSize="18" FontWeight="SemiBold"/>
                                <CheckBox x:Name="MinimizeToTrayCheckBox" Content="Keep Keywise running in the tray when I close the window" Margin="0,12,0,6"
                                          Foreground="{DynamicResource Ink}" Checked="MinimizeToTrayCheckBox_Changed" Unchecked="MinimizeToTrayCheckBox_Changed"/>
                                <TextBlock Text="Use Quit from the tray menu when you want Keywise to fully exit."
                                           Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Install Layout Plan" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="App: %LOCALAPPDATA%\Programs\Keywise\" Margin="0,12,0,0"/>
                                <TextBlock Text="Data: %LOCALAPPDATA%\Keywise\"/>
                                <TextBlock Text="Startup opt-in: Startup folder shortcut"/>
                                <TextBlock Text="Uninstall: remove app files, shortcuts, startup entry, and optionally local data"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Language" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Only English is active in this build. Other languages will be enabled after the interface text is fully translated."
                                           Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,4,0,12"/>
                                <ComboBox x:Name="LanguageComboBox" Width="260" HorizontalAlignment="Left" SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="English (United States)" Tag="en-US"/>
                                    <ComboBoxItem Content="Spanish (coming soon)" Tag="es" IsEnabled="False"/>
                                    <ComboBoxItem Content="French (coming soon)" Tag="fr" IsEnabled="False"/>
                                    <ComboBoxItem Content="German (coming soon)" Tag="de" IsEnabled="False"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCard}">
                            <StackPanel>
                                <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Keywise checks GitHub only when you click the button. It does not upload usage data or run background telemetry."
                                           Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Margin="0,4,0,14"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="CheckForUpdatesButton" Content="Check for updates" Click="CheckForUpdates_Click"/>
                                    <Button Content="Open releases" Click="OpenReleases_Click"/>
                                </StackPanel>
                                <ProgressBar x:Name="UpdateProgressBar" Height="10" Minimum="0" Maximum="100" Visibility="Collapsed" Margin="0,4,0,8"/>
                                <TextBlock x:Name="UpdateStatusText" Text="" Foreground="{DynamicResource Muted}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
